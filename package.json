{
	"name": "cassady-tech-site",
	"description": "Cassady Tech Solutions website on Astro and Cloudflare Workers.",
	"cloudflare": {
		"label": "Astro Framework Starter",
		"products": ["Workers"],
		"categories": [],
		"publish": true
	},
	"dependencies": {
		"@astrojs/cloudflare": "12.6.12",
		"@astrojs/mdx": "4.3.13",
		"@astrojs/rss": "4.0.14",
		"@astrojs/sitemap": "3.6.1",
		"astro": "5.16.9",
		"typescript": "5.9.3"
	},
	"devDependencies": {
		"wrangler": "4.56.0"
	},
	"engines": {
		"node": ">=22"
	},
	"private": true,
	"scripts": {
		"astro": "astro",
		"build": "astro build && node ./scripts/write-assetsignore.mjs",
		"cf-typegen": "wrangler types",
		"check": "astro build && node ./scripts/write-assetsignore.mjs && tsc && wrangler deploy --dry-run",
		"deploy": "node ./scripts/write-assetsignore.mjs && wrangler deploy",
		"dev": "astro dev",
		"preview": "astro build && node ./scripts/write-assetsignore.mjs && wrangler dev"
	},
	"type": "module"
}
