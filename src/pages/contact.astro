---
import SiteLayout from "../layouts/SiteLayout.astro";
const title = "Contact | Cassady Tech Solutions";
const description = "Contact Cassady Tech Solutions for security-focused managed IT support in Southern Colorado.";
---
<SiteLayout title={title} description={description} active="contact">
	<section class="page-title"><div class="section-inner"><p class="eyebrow">Contact</p><h1>Start a managed IT conversation.</h1><p>Share the business context, technical symptoms, and support priorities. Cassady Tech Solutions will use that information to shape a practical next step.</p></div></section>
	<section class="section"><div class="section-inner contact-layout"><div class="contact-list"><article class="contact-card direct-contact"><h2>Direct contact</h2><p><a href="mailto:samuelc@cassadytech.com">samuelc@cassadytech.com</a></p><p><a href="tel:+17197812356">719-781-2356</a></p><p>Serving Southern Colorado.</p></article><article class="contact-card"><h2>What to include</h2><p>Helpful details include affected devices, accounts, tools involved, recent changes, deadlines, error messages, and whether the issue is blocking work right now.</p></article><article class="contact-card"><h2>Good fit</h2><p>Small to mid-sized businesses needing managed IT support, endpoint help, account access support, backup awareness, website or hosting guidance, and vendor coordination.</p></article></div>
	<form class="form-card" method="post" action="/api/contact" data-contact-form><div class="form-grid"><div class="field"><label for="name">Name</label><input id="name" name="name" autocomplete="name" required maxlength="120" /></div><div class="field"><label for="email">Email</label><input id="email" name="email" type="email" autocomplete="email" required maxlength="180" /></div><div class="field"><label for="phone">Phone</label><input id="phone" name="phone" type="tel" autocomplete="tel" maxlength="40" /></div><div class="field"><label for="company">Company</label><input id="company" name="company" autocomplete="organization" maxlength="160" /></div><div class="field full"><label for="service">Support area</label><select id="service" name="service" required><option value="">Select one</option><option>Managed IT support</option><option>Device or workstation issue</option><option>Network, cloud, or account security help</option><option>Backup or continuity concern</option><option>Website, domain, or hosting support</option><option>Vendor, workflow, or automation handoff</option><option>Not sure yet</option></select></div><div class="field full"><label for="message">How can Cassady Tech Solutions help?</label><textarea id="message" name="message" required minlength="10" maxlength="2000"></textarea></div><div class="honeypot" aria-hidden="true"><label for="website">Website</label><input id="website" name="website" tabindex="-1" autocomplete="off" /></div><div class="field full"><button class="button" type="submit">Send request</button><p class="form-note">Your request will be sent directly to Cassady Tech Solutions.</p><p class="form-status" role="status" aria-live="polite" data-form-status></p></div></div></form></div></section>
</SiteLayout>