---
import SiteLayout from "../layouts/SiteLayout.astro";

const title = "Managed IT Services in Southern Colorado | Cassady Tech Solutions";
const description = "Security-focused managed IT support for small businesses in Colorado Springs, Pueblo, Rye, Walsenburg, and surrounding areas.";
const plans = [
  ["Starter / Essentials", "$60/user", "Intro or budget-conscious clients", "Basic monitoring, patching, endpoint protection, and limited remote support."],
  ["Basic", "$75/user", "Small offices needing core support", "Managed IT, monitoring, patching, help desk support, and foundational protection."],
  ["Standard", "$125/user", "Growing businesses", "Backup management, stronger identity support, and broader proactive maintenance."],
  ["Premium", "$175/user", "Higher-touch environments", "Priority support, strategic guidance, stronger security alignment, and faster response targets."],
];
---

<SiteLayout title={title} description={description} active="home">
<section class="hero">
  <div class="section-inner">
    <div>
      <p class="eyebrow">Managed IT services for Southern Colorado businesses</p>
      <h1>Security-Centric Managed IT and Support Services for Small Businesses</h1>
      <p class="lead">Cassady Tech Solutions helps small businesses manage devices, Microsoft 365, backups, networks, endpoint protection, and day-to-day technology operations without the enterprise runaround.</p>
      <div class="actions">
        <a class="button" href="/contact">Schedule a Technology Review</a>
        <a class="button secondary" href="/services">View Managed IT Services</a>
      </div>
      <div class="trust-strip" aria-label="Cassady Tech service strengths">
        <span>Local Southern Colorado support</span>
        <span>Remote-first service delivery</span>
        <span>Proactive monitoring and maintenance</span>
        <span>Practical cybersecurity built into IT operations</span>
      </div>
    </div>
    <div class="ops-panel" aria-label="Service highlights">
      <div class="logo-showcase">
        <img src="/assets/brand/official-logo.jpg" alt="Cassady Tech Solutions security-focused managed IT logo">
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="section-inner">
    <div class="section-heading">
      <p class="eyebrow">Business IT problems</p>
      <h2>Technology should not slow down your business.</h2>
      <p>Most small businesses do not need enterprise complexity. They need stable systems, clear access, monitored devices, reliable backups, and a practical security baseline.</p>
    </div>
    <div class="grid three pain-grid">
      {["Recurring computer issues and slow systems", "Account access problems and password confusion", "Unclear backup status or no disaster recovery plan", "Vendor, domain, hosting, or Microsoft 365 confusion", "No consistent documentation for systems, users, or devices", "Security concerns without a realistic starting point"].map((item) => <article class="value-card"><h3>{item}</h3></article>)}
    </div>
  </div>
</section>

<section class="section alt">
  <div class="section-inner">
    <div class="section-heading">
      <p class="eyebrow">Commercial managed IT</p>
      <h2>Focused support for the systems your organization depends on.</h2>
      <p>Recurring managed IT support, monitoring, maintenance, backup oversight, account security, endpoint protection, and practical documentation for small business operations.</p>
    </div>
    <div class="grid three">
      <article class="service-card"><span class="icon" aria-hidden="true"></span><h3>Managed IT Support and Operations</h3><p>Help desk support, system administration, vendor coordination, documentation, and day-to-day technology support.</p></article>
      <article class="service-card"><span class="icon">RM</span><h3>Remote Monitoring and Maintenance</h3><p>Endpoint monitoring, routine maintenance, patching, and proactive issue detection.</p></article>
      <article class="service-card"><span class="icon">BD</span><h3>Backup and Disaster Recovery</h3><p>Backup management, recovery planning, monitoring, and business continuity support.</p></article>
      <article class="service-card"><span class="icon">365</span><h3>Account and Identity Security</h3><p>Microsoft 365 support, account protection, MFA guidance, access cleanup, and basic risk reduction.</p></article>
      <article class="service-card"><span class="icon">EP</span><h3>Endpoint Protection</h3><p>Baseline endpoint security, protection oversight, and security-minded configuration support.</p></article>
      <article class="service-card"><span class="icon">DOC</span><h3>Documentation and Vendor Coordination</h3><p>Asset inventories, account maps, vendor notes, and process documentation that make support more consistent.</p></article>
    </div>
  </div>
</section>

<section class="section">
  <div class="section-inner">
    <div class="section-heading">
      <p class="eyebrow">Managed service plans</p>
      <h2>Simple commercial plan options.</h2>
      <p>Start with the support level that matches your business today, then mature your operations over time.</p>
    </div>
    <div class="plan-grid">
      {plans.map(([name, price, fit, summary]) => <article class="plan-card"><h3>{name}</h3><p class="plan-price">{price}</p><p><strong>Best fit:</strong> {fit}</p><p>{summary}</p></article>)}
    </div>
  </div>
</section>

<section class="section alt">
  <div class="section-inner grid two">
    <div class="content-block"><p class="eyebrow">Who we support</p><h2>Built for small businesses that need dependable IT without unnecessary complexity.</h2><p>Cassady Tech Solutions is a fit for small offices, nonprofits, professional services, local organizations, and hybrid teams that need recurring technology support with practical security built in.</p></div>
    <div class="content-block"><p class="eyebrow">Service area</p><h2>Serving Southern Colorado businesses.</h2><p>Serving small businesses across Southern Colorado, including Colorado Springs, Fountain, Pueblo, Rye, Walsenburg, and surrounding communities.</p></div>
  </div>
</section>

<section class="section band">
  <div class="section-inner">
    <div>
      <h2>Schedule a practical technology review.</h2>
      <p>Bring recurring issues, Microsoft 365 confusion, backup uncertainty, endpoint concerns, or vendor problems into focus.</p>
    </div>
    <a class="button" href="/contact">Schedule a Technology Review</a>
  </div>
</section>
</SiteLayout>
