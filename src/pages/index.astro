---
import SiteLayout from "../layouts/SiteLayout.astro";

const title = "Cassady Tech Solutions | Security-Focused Managed IT";
const description = "Cassady Tech Solutions provides security-focused managed IT and cybersecurity services for small to mid-sized businesses in Southern Colorado.";
---

<SiteLayout title={title} description={description} active="home">
<section class="hero">
        <div class="section-inner">
          <div>
            <p class="eyebrow">Security-focused managed IT in Southern Colorado</p>
            <h1>Reliable technology operations without the enterprise runaround.</h1>
            <p class="lead">Cassady Tech Solutions helps small to mid-sized businesses keep devices, accounts, backups, security basics, and daily systems running with steady, practical support.</p>
            <div class="actions">
              <a class="button" href="/contact">Request managed IT support</a>
              <a class="button secondary" href="/services">View services</a>
            </div>
          </div>
          <div class="ops-panel" aria-label="Service highlights">
            <div class="logo-showcase">
              <img src="/assets/brand/official-logo.jpg" alt="Cassady Tech Solutions logo">
            </div>
            <div class="status-strip service-summary">
              <span class="status-dot" aria-hidden="true"></span>
              <div><strong>Practical tech review</strong><span>A clear look at operational risk, recurring issues, and what to fix first.</span></div>
              <span>Review</span>
            </div>
            <div class="metric-grid">
              <div class="metric-card"><strong>01</strong><span>Responsive support for business-critical interruptions.</span></div>
              <div class="metric-card"><strong>02</strong><span>Endpoint, account, and patch management guidance.</span></div>
              <div class="metric-card"><strong>03</strong><span>Backup oversight, vendor coordination, and cloud support.</span></div>
              <div class="metric-card"><strong>04</strong><span>Better documentation so operations stay consistent.</span></div>
            </div>
          </div>
        </div>
      </section>

      <section class="section">
        <div class="section-inner">
          <div class="section-heading">
            <p class="eyebrow">Managed operations</p>
            <h2>Focused support for the systems your organization depends on.</h2>
            <p>Support should feel calm, direct, and grounded in the way each organization actually works.</p>
          </div>
          <div class="grid three">
            <article class="service-card">
              <span class="icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M4 5h16v10H4zM8 19h8M10 15v4M14 15v4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg></span>
              <h3>Endpoints and devices</h3>
              <p>Setup, troubleshooting, maintenance guidance, software support, and practical lifecycle planning for everyday workstations.</p>
            </article>
            <article class="service-card">
              <span class="icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M12 3v6M6 21v-5a6 6 0 0 1 12 0v5M6 15h12M8 9h8" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg></span>
              <h3>Accounts, networks, and cloud tools</h3>
              <p>Wi-Fi, routers, user accounts, email, file sharing, backup oversight, and the cloud services that keep work moving.</p>
            </article>
            <article class="service-card">
              <span class="icon" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg></span>
              <h3>Security-aligned workflow support</h3>
              <p>Help with domains, hosting, vendor coordination, form workflows, automation handoffs, and clean technical documentation.</p>
            </article>
          </div>
        </div>
      </section>

      <section class="section alt">
        <div class="section-inner">
          <div class="section-heading">
            <p class="eyebrow">How it works</p>
            <h2>Simple support with security-minded follow-through.</h2>
          </div>
          <div class="grid three">
            <article class="timeline-card">
              <h3>Assess</h3>
              <p>Start with the issue, the business impact, and the systems already in place.</p>
            </article>
            <article class="timeline-card">
              <h3>Stabilize</h3>
              <p>Fix what is urgent, document the cause, and identify preventable operational or security gaps.</p>
            </article>
            <article class="timeline-card">
              <h3>Improve</h3>
              <p>Recommend right-sized improvements for continuity, security, and day-to-day operations.</p>
            </article>
          </div>
        </div>
      </section>

      <section class="section band">
        <div class="section-inner">
          <div>
            <h2>Bring a technology problem into focus.</h2>
            <p>Send the basics and Cassady Tech Solutions will help turn the problem into a clear next step.</p>
          </div>
          <a class="button" href="/contact">Request support</a>
        </div>
      </section>
</SiteLayout>
